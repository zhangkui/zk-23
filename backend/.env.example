# 服务配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
RUST_LOG=info,cableway_monitor=debug

# ClickHouse 配置
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=cableway_monitor

# NATS 配置
NATS_HOST=127.0.0.1
NATS_PORT=4222
NATS_USER=
NATS_PASSWORD=

# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT 配置
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRE_HOURS=24

# 系统配置
ICE_ALERT_THRESHOLD_MM=10.0
VIBRATION_ALERT_THRESHOLD_MMS=5.0
WIND_SPEED_THRESHOLD_MS=25.0

# 视频服务配置
VIDEO_SERVER_URL=http://127.0.0.1:8090
VIDEO_API_KEY=your-video-api-key

# 边缘节点配置
NODE_ID=edge-001
NODE_LOCATION=景区入口
